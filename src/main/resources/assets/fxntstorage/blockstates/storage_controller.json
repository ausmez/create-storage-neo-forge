{
  "multipart": [
    {
      "when": {
        "facing": "north"
      },
      "apply": {
        "model": "fxntstorage:block/storage_controller"
      }
    },
    {
      "when": {
        "facing": "east"
      },
      "apply": {
        "model": "fxntstorage:block/storage_controller",
        "y": 90
      }
    },
    {
      "when": {
        "facing": "south"
      },
      "apply": {
        "model": "fxntstorage:block/storage_controller",
        "y": 180
      }
    },
    {
      "when": {
        "facing": "west"
      },
      "apply": {
        "model": "fxntstorage:block/storage_controller",
        "y": 270
      }
    },
    {
      "when": {
        "facing": "north",
        "connected_to_network": true
      },
      "apply": {
        "model": "fxntstorage:block/storage_controller_connected"
      }
    },
    {
      "when": {
        "facing": "east",
        "connected_to_network": true
      },
      "apply": {
        "model": "fxntstorage:block/storage_controller_connected",
        "y": 90
      }
    },
    {
      "when": {
        "facing": "south",
        "connected_to_network": true
      },
      "apply": {
        "model": "fxntstorage:block/storage_controller_connected",
        "y": 180
      }
    },
    {
      "when": {
        "facing": "west",
        "connected_to_network": true
      },
      "apply": {
        "model": "fxntstorage:block/storage_controller_connected",
        "y": 270
      }
    }
  ]
}